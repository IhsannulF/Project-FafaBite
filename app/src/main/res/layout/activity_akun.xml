<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fafa_blue_primary">

    <!-- ========================================== -->
    <!-- KONTEN HALAMAN PROFIL (Desain Baru Kamu) -->
    <!-- ========================================== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <!-- Tambahkan paddingBottom agar konten paling bawah tidak tertutup Navbar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <!-- Header Teks "Profile" -->
            <TextView
                android:id="@+id/tvHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="Profile"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Wadah Putih Melengkung -->
            <View
                android:id="@+id/whiteContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="120dp"
                android:background="@drawable/bg_top_rounded_white"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Lingkaran Foto Profil -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvProfileImage"
                android:layout_width="100dp"
                android:layout_height="100dp"
                app:cardCornerRadius="50dp"
                app:cardElevation="8dp"
                app:strokeColor="@color/white"
                app:strokeWidth="6dp"
                app:layout_constraintBottom_toTopOf="@id/whiteContainer"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/whiteContainer">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/fafa_bg_grey"
                    android:padding="20dp"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="@color/fafa_blue_primary" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Nama Lengkap -->
            <TextView
                android:id="@+id/tvProfilNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Muhammad Ihsanul Fikri"
                android:textColor="@color/text_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cvProfileImage" />

            <!-- Email & No HP -->
            <TextView
                android:id="@+id/tvProfilDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ihsanul@fafabite.com • 08123456789"
                android:textColor="@color/text_grey"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvProfilNama" />

            <!-- Card Melayang (Quick Actions) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvQuickActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:layout_constraintTop_toBottomOf="@id/tvProfilDetail">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <!-- Action 1: Wishlist -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/star_off"
                            app:tint="@color/text_dark" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Wishlist"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Action 2: Alamat -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_dialog_map"
                            app:tint="@color/text_dark" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Alamat"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Action 3: Pembayaran -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="@color/text_dark" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Bayar"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Label GENERAL -->
            <TextView
                android:id="@+id/tvLabelGeneral"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="GENERAL"
                android:textColor="@color/text_grey"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cvQuickActions" />

            <!-- Daftar Menu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="32dp"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvLabelGeneral">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:paddingVertical="16dp"
                    android:text="Pengaturan Notifikasi"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:paddingVertical="16dp"
                    android:text="Bantuan &amp; Customer Service"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:paddingVertical="16dp"
                    android:text="Kebijakan &amp; Syarat Penggunaan"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" />

                <!-- PERHATIKAN: ID-nya saya sesuaikan dengan yang ada di AkunActivity.kt -->
                <TextView
                    android:id="@+id/tvLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:paddingVertical="16dp"
                    android:text="Logout"
                    android:textColor="#FF3B30"
                    android:textStyle="bold"
                    android:textSize="16sp" />

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- ========================================== -->
    <!-- NAVBAR BAWAH (BottomAppBar) -->
    <!-- ========================================== -->
    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:backgroundTint="@color/white"
        app:fabAlignmentMode="center"
        app:fabCradleMargin="10dp"
        app:fabCradleRoundedCornerRadius="24dp"
        app:fabCradleVerticalOffset="6dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigationView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:elevation="0dp"
            app:itemIconTint="@color/text_grey"
            app:itemTextColor="@color/text_grey"
            app:menu="@menu/bottom_nav_menu" />

    </com.google.android.material.bottomappbar.BottomAppBar>

    <!-- ========================================== -->
    <!-- TOMBOL TENGAH MELAYANG (Cari Lokasi) -->
    <!-- ========================================== -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCariLokasi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Cari Lokasi"
        app:backgroundTint="@color/fafa_blue_primary"
        app:elevation="6dp"
        app:layout_anchor="@id/bottomAppBar"
        app:maxImageSize="28dp"
        app:srcCompat="@android:drawable/ic_dialog_map"
        app:tint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>