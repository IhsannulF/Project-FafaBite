<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <!-- HEADER -->
            <LinearLayout
                android:id="@+id/headerPesananResto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FF9800"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="40dp"
                android:paddingBottom="24dp"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pesanan Masuk"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Kelola pesanan dari pembeli dengan cepat"
                    android:textColor="#FFE0B2"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- TAB FILTER (Mockup) -->
            <HorizontalScrollView
                android:id="@+id/scrollTabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:paddingHorizontal="24dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/headerPesananResto">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Tab Aktif -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input_pill"
                        android:backgroundTint="#FF9800"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Semua Aktif"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <!-- Tab Pasif -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_input_pill"
                        android:backgroundTint="#E0E0E0"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Menunggu"
                        android:textColor="@color/text_grey" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_input_pill"
                        android:backgroundTint="#E0E0E0"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Diproses"
                        android:textColor="@color/text_grey" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- DAFTAR PESANAN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/scrollTabs">

                <!-- PESANAN 1: PESANAN BARU (Menunggu Konfirmasi) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Order #FAFA-8892"
                                android:textColor="@color/text_dark"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#FFF3E0"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:text="Pesanan Baru"
                                android:textColor="#FF9800"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="#EEEEEE" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pemesan: Muhammad Ihsanul"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="3x Roti Sisa Kemarin (Rp 30.000)"
                            android:textColor="@color/text_grey" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Waktu Pickup: 19:00 - 20:00"
                            android:textColor="@color/text_grey"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal">

                            <Button
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:backgroundTint="#F5F5F5"
                                android:text="Tolak"
                                android:textColor="@color/text_dark"
                                app:cornerRadius="8dp" />

                            <Button
                                android:id="@+id/btnTerimaPesanan"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_weight="1"
                                android:backgroundTint="#FF9800"
                                android:text="Terima"
                                android:textColor="@color/white"
                                app:cornerRadius="8dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- PESANAN 2: SIAP DIAMBIL (Butuh Scan QR) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Order #FAFA-1104"
                                android:textColor="@color/text_dark"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#E8F5E9"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:text="Siap Diambil"
                                android:textColor="#4CAF50"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="12dp" android:background="#EEEEEE" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pemesan: Almaaa"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="1x Nasi Bento Box (Rp 15.000)"
                            android:textColor="@color/text_grey" />

                        <Button
                            android:id="@+id/btnScanQR"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:backgroundTint="#4CAF50"
                            android:drawableLeft="@android:drawable/ic_menu_camera"
                            android:text="Scan QR Code Pembeli"
                            android:textColor="@color/white"
                            app:cornerRadius="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- NAVBAR BAWAH KHUSUS RESTORAN -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavResto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        app:elevation="8dp"
        app:itemIconTint="#FF9800"
        app:itemTextColor="#FF9800"
        app:menu="@menu/menu_resto_nav" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>