<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <!-- HEADER PROFIL (Warna Biru FafaBite) -->
            <LinearLayout
                android:id="@+id/headerProfilResto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/fafa_blue_primary"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:paddingTop="40dp"
                android:paddingBottom="40dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- Foto Profil Restoran -->
                <androidx.cardview.widget.CardView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    app:cardCornerRadius="35dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#E3F2FD"
                        android:padding="16dp"
                        android:src="@android:drawable/ic_menu_camera"
                        app:tint="@color/fafa_blue_primary" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toko Roti Makmur"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="admin@tokoroti.com"
                        android:textColor="#E3F2FD"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- CARD SALDO KEUANGAN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvSaldoKeuangan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="-20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/headerProfilResto">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Saldo Penjual"
                            android:textColor="@color/text_grey"
                            android:textSize="12sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Rp 450.000"
                            android:textColor="@color/text_dark"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <Button
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/fafa_blue_primary"
                        android:text="Tarik Dana"
                        android:textAllCaps="false"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- PENGATURAN TOKO -->
            <TextView
                android:id="@+id/tvLabelPengaturan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="32dp"
                android:text="PENGATURAN TOKO"
                android:textColor="@color/text_grey"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cvSaldoKeuangan" />

            <LinearLayout
                android:id="@+id/layoutPengaturan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@color/white"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/tvLabelPengaturan">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:drawableStart="@android:drawable/ic_menu_edit"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:drawablePadding="16dp"
                    android:gravity="center_vertical"
                    android:text="Informasi &amp; Lokasi Toko"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    app:drawableTint="@color/text_dark" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:drawableStart="@android:drawable/ic_menu_recent_history"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:drawablePadding="16dp"
                    android:gravity="center_vertical"
                    android:text="Jam Operasional"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    app:drawableTint="@color/text_dark" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:drawableStart="@android:drawable/ic_menu_help"
                    android:drawableEnd="@android:drawable/ic_media_next"
                    android:drawablePadding="16dp"
                    android:gravity="center_vertical"
                    android:text="Pusat Bantuan Penjual"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    app:drawableTint="@color/text_dark" />
            </LinearLayout>

            <!-- TOMBOL LOGOUT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@color/white"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@+id/layoutPengaturan"
                app:layout_constraintVertical_bias="1.0"
                app:layout_constraintBottom_toBottomOf="parent">

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" />

                <TextView
                    android:id="@+id/tvLogoutResto"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:drawableStart="@android:drawable/ic_menu_close_clear_cancel"
                    android:drawablePadding="16dp"
                    android:gravity="center_vertical"
                    android:text="Keluar Akun (Logout)"
                    android:textColor="#F44336"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:drawableTint="#F44336" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- NAVBAR BAWAH KHUSUS RESTORAN -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavResto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        app:elevation="8dp"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:menu="@menu/menu_resto_nav" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>