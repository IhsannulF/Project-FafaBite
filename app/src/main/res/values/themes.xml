<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.FafaBite" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Warna Utama Aplikasi (Biru) -->
        <item name="colorPrimary">@color/fafa_blue_primary</item>
        <item name="colorPrimaryVariant">#004BBA</item> <!-- Biru lebih gelap untuk status bar -->
        <item name="colorOnPrimary">@color/white</item>

        <!-- Warna Sekunder (Bisa disamakan biru atau abu-abu) -->
        <item name="colorSecondary">@color/fafa_blue_primary</item>
        <item name="colorSecondaryVariant">#004BBA</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Warna Status Bar (Bagian atas HP yang ada jam/sinyal) -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>
</resources>